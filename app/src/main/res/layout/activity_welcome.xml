<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:padding="24dp"
    tools:context=".WelcomeActivity">

    <!-- Main Content Container -->
    <LinearLayout
        android:layout_width="343dp"
        android:layout_height="619dp"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Large illustration (keep as-is) -->
        <ImageView
            android:id="@+id/ivIllustration"
            android:layout_width="308dp"
            android:layout_height="306dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="@string/app_logo"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_pawsitive_logo" />

        <!-- Pawsitive Logo Image (same as login text logo) -->

        <!-- Tagline -->

        <!-- Get Started Button -->

        <ImageView
            android:id="@+id/ivPawsitiveLogoWelcome"
            android:layout_width="247dp"
            android:layout_height="65dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_logo"
            android:scaleType="centerInside"
            android:src="@drawable/logo_pawsitive" />

        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="173dp"
            android:layout_height="35dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="40dp"
            android:text="@string/tagline"
            android:textColor="@color/gray_text"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnGetStarted"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/btn_rounded_yellow"
            android:elevation="4dp"
            android:text="@string/get_started"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Already have account text -->
        <TextView
            android:id="@+id/tvLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:clickable="true"
            android:focusable="true"
            android:text="@string/already_have_account"
            android:textColor="@color/gray_dark"
            android:textSize="14sp" />

    </LinearLayout>

</RelativeLayout>
