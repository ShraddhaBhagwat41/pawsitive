<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTaskAnimalIcon"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="A"
                android:textColor="@color/gray_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/distance_background" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTaskAnimalType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dog"
                    android:textColor="@color/gray_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTaskCondition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Condition: Injured"
                    android:textColor="@color/gray_text"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTaskStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp"
                android:text="Assigned"
                android:textColor="@color/staff_status_assigned"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTaskAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Location"
            android:textColor="@color/gray_dark"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTaskDistance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Distance: --"
                android:textColor="@color/gray_text"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvTaskAssignedTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assigned: --"
                android:textColor="@color/gray_text"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTaskMap"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/btn_rounded_yellow"
                android:text="Map"
                android:textAllCaps="false"
                android:textColor="@android:color/white" />

            <Space
                android:layout_width="6dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnTaskCall"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/btn_secondary_background"
                android:text="Call NGO"
                android:textAllCaps="false"
                android:textColor="@color/gray_dark" />

            <Space
                android:layout_width="6dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnTaskOnTheWay"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/btn_secondary_background"
                android:text="On the Way"
                android:textAllCaps="false"
                android:textColor="@color/gray_dark" />

            <Space
                android:layout_width="6dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnTaskComplete"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/btn_rounded_yellow"
                android:text="Completed"
                android:textAllCaps="false"
                android:textColor="@android:color/white" />
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
