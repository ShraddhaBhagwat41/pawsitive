<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context=".auth.RoleSelectionActivity">

    <TextView
        android:id="@+id/tvRoleTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Who are you?"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/gray_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="64dp" />

    <RadioGroup
        android:id="@+id/rgRoles"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/tvRoleTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp">

        <RadioButton
            android:id="@+id/rbUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User (Animal Lover)" />

        <RadioButton
            android:id="@+id/rbNgo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NGO / Rescue Organization" />
    </RadioGroup>

    <Button
        android:id="@+id/btnContinueRole"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Continue"
        android:background="@drawable/btn_rounded_yellow"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/rgRoles"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>

