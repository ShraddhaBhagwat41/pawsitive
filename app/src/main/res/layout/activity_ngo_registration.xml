<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ngoRegistrationScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true"
    tools:context=".ngo.NGORegistrationActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Title Section -->
        <LinearLayout
            android:id="@+id/llNgoTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NGO"
                android:textColor="@color/gray_dark"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Registration"
                android:textColor="@color/yellow_primary"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Complete your profile to join Pawsitive!"
            android:textColor="@color/gray_text"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llNgoTitle"
            android:layout_marginTop="4dp" />

        <!-- Profile Photo Section -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvProfile"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="40dp"
            app:cardElevation="2dp"
            android:layout_marginTop="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

            <ImageView
                android:id="@+id/ivNgoProfilePhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_user_placeholder"
                tools:ignore="ContentDescription" />
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnChangeNgoPhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_rounded_yellow"
            android:text="CHANGE PHOTO"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:minHeight="40dp"
            app:layout_constraintBottom_toBottomOf="@id/cvProfile"
            app:layout_constraintStart_toEndOf="@id/cvProfile"
            app:layout_constraintTop_toTopOf="@id/cvProfile"
            android:layout_marginStart="12dp" />

        <!-- Form Fields -->
        <LinearLayout
            android:id="@+id/llInputs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/cvProfile">

            <!-- NGO Name -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/input_field_background">
                <ImageView
                    android:id="@+id/ivNameIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_user"
                    app:tint="@color/gray_text" />
                <EditText
                    android:id="@+id/etNgoName"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toEndOf="@id/ivNameIcon"
                    android:background="@null"
                    android:hint="NGO Name"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="@color/gray_dark"
                    android:textSize="16sp"
                    android:inputType="textCapWords" />
            </RelativeLayout>

            <!-- Phone Number -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/input_field_background">
                <ImageView
                    android:id="@+id/ivPhoneIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_username"
                    app:tint="@color/gray_text" />
                <EditText
                    android:id="@+id/etNgoPhone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toEndOf="@id/ivPhoneIcon"
                    android:background="@null"
                    android:hint="Phone Number"
                    android:inputType="phone"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="@color/gray_dark"
                    android:textSize="16sp" />
            </RelativeLayout>

            <!-- Address -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/input_field_background">
                <ImageView
                    android:id="@+id/ivAddressIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_location"
                    app:tint="@color/gray_text" />
                <EditText
                    android:id="@+id/etNgoAddress"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toEndOf="@id/ivAddressIcon"
                    android:background="@null"
                    android:hint="Address"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="@color/gray_dark"
                    android:textSize="16sp" />
            </RelativeLayout>

            <!-- License Number -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/input_field_background">
                <ImageView
                    android:id="@+id/ivLicenseIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_pawsitive_logo"
                    app:tint="@color/gray_text" />
                <EditText
                    android:id="@+id/etNgoLicense"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toEndOf="@id/ivLicenseIcon"
                    android:background="@null"
                    android:hint="License Number"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="@color/gray_dark"
                    android:textSize="16sp" />
            </RelativeLayout>

            <!-- Certificate Upload Button -->
            <Button
                android:id="@+id/btnUploadCertificate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/input_field_background_gray"
                android:text="UPLOAD CERTIFICATE (IMAGE/PDF)"
                android:textAllCaps="false"
                android:textColor="@color/gray_dark" />

            <TextView
                android:id="@+id/tvCertificateStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="No certificate selected"
                android:textColor="@color/gray_text"
                android:textSize="12sp" />

            <!-- Description -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/input_field_background">
                <ImageView
                    android:id="@+id/ivDescIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_message"
                    app:tint="@color/gray_text" />
                <EditText
                    android:id="@+id/etNgoDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ivDescIcon"
                    android:background="@null"
                    android:hint="NGO Description"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:padding="12dp"
                    android:textColor="@color/gray_dark"
                    android:textSize="16sp" />
            </RelativeLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnSendForVerification"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/btn_rounded_yellow"
            android:text="SIGN UP"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/llInputs"
            android:layout_marginTop="16dp" />

        <!-- Status Message -->
        <TextView
            android:id="@+id/tvNgoStatusMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:textColor="@color/green_success"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnSendForVerification"
            tools:text="details sent for verification"
            tools:visibility="visible" />

        <!-- Login Redirect Link -->
        <TextView
            android:id="@+id/tvLoginRedirect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Can check status by login"
            android:textColor="@color/yellow_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvNgoStatusMessage"
            tools:visibility="visible" />

        <ProgressBar
            android:id="@+id/progressNgo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
