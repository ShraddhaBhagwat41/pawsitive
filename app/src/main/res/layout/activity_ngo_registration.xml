<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context=".ngo.NGORegistrationActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <ImageView
            android:id="@+id/ivNgoProfilePhoto"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_profile_placeholder"
            android:scaleType="centerCrop"
            android:contentDescription="NGO profile photo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/btnChangeNgoPhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change Photo"
            app:layout_constraintStart_toEndOf="@id/ivNgoProfilePhoto"
            app:layout_constraintBottom_toBottomOf="@id/ivNgoProfilePhoto"
            android:layout_marginStart="16dp" />

        <EditText
            android:id="@+id/etNgoName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="NGO Name"
            app:layout_constraintTop_toBottomOf="@id/ivNgoProfilePhoto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

        <EditText
            android:id="@+id/etNgoPhone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Phone Number"
            android:inputType="phone"
            app:layout_constraintTop_toBottomOf="@id/etNgoName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/etNgoAddress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Address"
            android:inputType="textPostalAddress"
            app:layout_constraintTop_toBottomOf="@id/etNgoPhone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/etNgoLicense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="License Number"
            app:layout_constraintTop_toBottomOf="@id/etNgoAddress"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnUploadCertificate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Upload Certificate (image/pdf)"
            app:layout_constraintTop_toBottomOf="@id/etNgoLicense"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvCertificateStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="No certificate selected"
            app:layout_constraintTop_toBottomOf="@id/btnUploadCertificate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/etNgoDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Description"
            android:inputType="textMultiLine"
            android:minLines="3"
            app:layout_constraintTop_toBottomOf="@id/tvCertificateStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnSendForVerification"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Send for Verification"
            android:background="@drawable/btn_rounded_yellow"
            android:textColor="@android:color/white"
            app:layout_constraintTop_toBottomOf="@id/etNgoDescription"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

        <ProgressBar
            android:id="@+id/progressNgo"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>

