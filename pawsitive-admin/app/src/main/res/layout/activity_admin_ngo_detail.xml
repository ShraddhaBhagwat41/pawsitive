<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light"
    android:padding="16dp">

    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_media_previous"
        android:tint="@color/brown_dark" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="PENDING"
        android:textColor="@color/blue_pending"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvOrgName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Organization Name"
        android:textColor="@color/gray_dark"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView android:id="@+id/tvPhone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textColor="@color/gray_dark" />
    <TextView android:id="@+id/tvAddress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textColor="@color/gray_dark" />
    <TextView android:id="@+id/tvLicense" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textColor="@color/gray_dark" />
    <TextView android:id="@+id/tvDescription" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textColor="@color/gray_dark" />

    <Button
        android:id="@+id/btnViewCertificate"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:text="VIEW CERTIFICATE"
        android:backgroundTint="@color/yellow_primary"
        android:textColor="@color/brown_dark" />

    <EditText
        android:id="@+id/etNotes"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="16dp"
        android:background="@android:drawable/edit_text"
        android:gravity="top"
        android:hint="Enter notes or rejection reason"
        android:padding="12dp" />

    <Button
        android:id="@+id/btnReject"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:text="REJECT NGO"
        android:backgroundTint="@color/red_primary"
        android:textColor="@color/white" />

    <Button
        android:id="@+id/btnApprove"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:text="APPROVE NGO"
        android:backgroundTint="@color/green_success"
        android:textColor="@color/white" />

</LinearLayout>

