<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@android:color/white">

    <!-- Login Button at the Top Right -->
    <Button
        android:id="@+id/btnGoToLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Login"
        android:textAllCaps="false"
        android:background="@drawable/btn_rounded_yellow"
        android:textColor="@android:color/white"
        android:paddingHorizontal="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvVerifyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verify your email"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/gray_dark"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvVerifyMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="We have sent a verification link to your email. Please check your inbox and verify your email to continue."
            android:textSize="16sp"
            android:gravity="center"
            android:textColor="@color/gray_text"
            android:layout_marginBottom="32dp" />

        <!-- Verified Badge -->
        <TextView
            android:id="@+id/tvVerifiedStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verified ✓"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/green_success"
            android:layout_marginBottom="32dp"
            android:visibility="gone"
            android:padding="16dp"
            android:background="@drawable/input_field_background" />

        <Button
            android:id="@+id/btnResendEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Resend verification email"
            android:textAllCaps="false"
            android:background="@drawable/btn_rounded_yellow"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
