<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Pawsitive"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Welcome Activity - Launcher Activity -->
        <activity
            android:name="com.pawsitive.app.WelcomeActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Admin Dashboard Activity -->
        <activity
            android:name="com.pawsitive.app.admin.AdminHomeActivity"
            android:exported="false" />

        <!-- Admin NGO Detail Activity -->
        <activity
            android:name="com.pawsitive.app.admin.AdminNGODetailActivity"
            android:exported="true" />

        <!-- Main Activity -->
        <activity
            android:name="com.pawsitive.app.MainActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Login Activity -->
        <activity
            android:name="com.pawsitive.app.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Signup Activity -->
        <activity
            android:name="com.pawsitive.app.SignupActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Report Animal Activity -->
        <activity
            android:name="com.pawsitive.app.ReportAnimalActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Home Activity -->
        <activity
            android:name="com.pawsitive.app.HomeActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Pet Profile Activity -->
        <activity android:name="com.pawsitive.app.PetProfileActivity" />

        <!-- New auth/registration activities -->
        <activity android:name="com.pawsitive.app.auth.RoleSelectionActivity" />
        <activity android:name="com.pawsitive.app.user.UserProfileActivity" />
        <activity android:name="com.pawsitive.app.ngo.NGORegistrationActivity" />
        <activity android:name="com.pawsitive.app.user.UserHomeActivity" />
        <activity android:name="com.pawsitive.app.ngo.NGOHomeActivity" />

        <!-- Email Verification Activity -->
        <activity android:name="com.pawsitive.app.VerifyEmailActivity" />

    </application>

</manifest>
